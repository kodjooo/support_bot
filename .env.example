# Токен Telegram-бота
# Получить у @BotFather в Telegram: /newbot
TELEGRAM_BOT_TOKEN=your-telegram-bot-token

# Ключ OpenAI API
# Получить на https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# Модель OpenAI для Responses API
# Доступные модели: gpt-4o, gpt-4o-mini, o3, o4-mini и др.
OPENAI_MODEL=gpt-4o

# Путь к файлу с системным промптом (относительно рабочей директории контейнера /app)
# Содержимое файла передаётся как instructions при каждом новом диалоге
# Отредактируйте system_prompt.txt — он находится в корне проекта
OPENAI_SYSTEM_PROMPT_FILE=system_prompt.txt

# Температура ответов (0.0 — точно/детерминированно, 2.0 — максимально случайно)
# Оставьте закомментированным для дефолтного значения модели
# Не поддерживается моделями o-серии (o3, o4-mini и др.)
# OPENAI_TEMPERATURE=0.7

# Уровень рассуждения — только для моделей o-серии (o3, o4-mini и др.)
# Значения: low, medium, high
# Оставьте закомментированным для gpt-серии
# OPENAI_REASONING_EFFORT=medium

# Chat ID оператора (куда слать уведомления)
# Узнать свой chat_id можно через @userinfobot в Telegram
OPERATOR_CHAT_ID=123456789

# Имя оператора (подставляется в сообщение пользователю)
OPERATOR_NAME=Оператор

# Путь к SQLite-файлу внутри контейнера (volume монтируется в /app/data)
DATABASE_PATH=./data/chatbot.db

# Секунд ожидания паузы перед обработкой (рекомендуется 3-5)
DEBOUNCE_DELAY=4

# Секунд до устаревания буфера (1 час)
MAX_BUFFER_AGE=3600

# Максимум картинок за одну сессию
MAX_IMAGES=10

# Минимальная ширина фото в пикселях
MIN_PHOTO_WIDTH=800

# Секунд ожидания ответа от OpenAI
OPENAI_RUN_TIMEOUT=60

# URL сервиса векторного поиска (vector-base-for-bot)
# Если оба проекта в одной Docker-сети: http://vector-base:8080
# Если на отдельном сервере: http://<IP>:8080
# Оставьте пустым, если векторная база не используется
VECTOR_BASE_URL=
